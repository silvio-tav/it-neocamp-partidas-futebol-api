            "description": "Retorna os dados de um clube específico pelo seu ID.\n\n**Respostas esperadas:**\n- `200 OK` — clube encontrado com sucesso\n- `404 Not Found` — clube não encontrado"
          },
          "response": [
            {
              "name": "200 - Clube encontrado",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"clubeId\": \"b1b2c3d4-0001-0000-0000-000000000001\",\n  \"nome\": \"Flamengo\",\n  \"siglaEstado\": \"RJ\",\n  \"dataCriacao\": \"1895-11-15\",\n  \"ativo\": true\n}"
            },
