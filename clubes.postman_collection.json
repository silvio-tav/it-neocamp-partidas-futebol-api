              "body": "{\n  \"status\": 404,\n  \"detail\": \"Clube com o id b1b2c3d4-0001-0000-0000-000000000001 não encontrado\"\n}"
            }
          ]
        },
        {
          "name": "Listar clubes",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/clubes?nome=&estado=&ativo=&page=0&size=10&sort=nome,asc",
              "host": ["{{baseUrl}}"],
              "path": ["clubes"],
              "query": [
                { "key": "nome", "value": "", "description": "Filtrar por trecho do nome do clube (ex: Fla)", "disabled": true },
                { "key": "estado", "value": "", "description": "Filtrar por sigla do estado (ex: RJ, SP, MG)", "disabled": true },
                { "key": "ativo", "value": "", "description": "Filtrar por situação: true = ativos, false = inativos", "disabled": true },
                { "key": "page", "value": "0", "description": "Número da página (começa em 0)" },
                { "key": "size", "value": "10", "description": "Quantidade de registros por página" },
