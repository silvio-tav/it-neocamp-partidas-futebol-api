              "body": "{\n  \"content\": [\n    {\n      \"clubeId\": \"b1b2c3d4-0001-0000-0000-000000000001\",\n      \"nome\": \"Flamengo\",\n      \"siglaEstado\": \"RJ\",\n      \"dataCriacao\": \"1895-11-15\",\n      \"ativo\": true\n    },\n    {\n      \"clubeId\": \"b1b2c3d4-0002-0000-0000-000000000002\",\n      \"nome\": \"Fluminense\",\n      \"siglaEstado\": \"RJ\",\n      \"dataCriacao\": \"1902-07-21\",\n      \"ativo\": true\n    }\n  ],\n  \"pageable\": { \"pageNumber\": 0, \"pageSize\": 10 },\n  \"totalElements\": 2,\n  \"totalPages\": 1,\n  \"last\": true,\n  \"first\": true,\n  \"empty\": false\n}"
